#!/usr/bin/env bash
set -euo pipefail

_script="${BASH_SOURCE[0]}"
while [[ -L "$_script" ]]; do
  _dir="$(cd "$(dirname "$_script")" && pwd)"
  _script="$(readlink "$_script")"
  [[ "$_script" != /* ]] && _script="$_dir/$_script"
done
TOOLKIT_DIR="$(cd "$(dirname "$_script")" && pwd)"
# shellcheck source=lib/common.sh
source "$TOOLKIT_DIR/lib/common.sh"

usage() {
  cat <<EOF
Usage: multi-colab-ide [account-id] [ide args...]

Launch your IDE with an isolated Google Cloud / Colab credential profile.

Configure the IDE command in:
  ~/.config/multi-colab-ide/ide.conf

Examples:
  multi-colab-ide              # interactive account menu
  multi-colab-ide 2            # launch IDE with account 2
  multi-colab-ide 2 .          # open current directory in IDE
EOF
}

main() {
  local choice="${1:-}"
  if [[ -z "$choice" ]]; then
    print_account_menu
    read -r -p "Choice: " choice
  else
    shift
  fi

  load_accounts

  local idx
  if ! idx="$(find_account_index "$choice")"; then
    echo "Invalid choice: $choice" >&2
    exit 1
  fi

  local config_dir="${ACCOUNT_DIRS[$idx]}"
  local label="${ACCOUNT_LABELS[$idx]}"

  apply_account_env "$config_dir"
  load_ide_config

  local ide_path
  ide_path="$(ide_bin)"

  echo
  echo "Launching IDE with:"
  echo "  Account : $label"
  echo "  IDE     : $IDE_COMMAND"
  echo "  Config  : $CLOUDSDK_CONFIG"
  echo

  if ! adc_configured; then
    echo "Warning: ADC not set up for this profile yet."
    echo "Run once:"
    echo "  mci-setup $choice"
    echo
  fi

  if [[ ! -x "$ide_path" ]] && ! command -v "$IDE_COMMAND" >/dev/null 2>&1; then
    echo "IDE command not found: $IDE_COMMAND" >&2
    echo "Edit $IDE_CONFIG or $TOOLKIT_DIR/config/ide.conf.example" >&2
    exit 1
  fi

  # shellcheck disable=SC2086
  exec "$ide_path" $IDE_ARGS "$@"
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

main "$@"
